{
  "name": "@pawel-up/html.md",
  "version": "0.2.1",
  "description": "No-dependency, ESM, in browser HTML to markdown converter",
  "license": "CC-BY-4.0",
  "main": "build/index.js",
  "module": "build/index.js",
  "types": "build/index.d.ts",
  "type": "module",
  "keywords": [
    "markdown",
    "html"
  ],
  "author": {
    "name": "Pawel Uchida-Psztyc"
  },
  "contributors": [
    "Your name can be here!"
  ],
  "repository": {
    "type": "git",
    "url": "git://github.com/pawel-up/html.md.git"
  },
  "bugs": {
    "url": "https://github.com/pawel-up/html.md/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "docs": "typedoc",
    "build": "tsc --build tsconfig.build.json --pretty",
    "prepublish": "tsc",
    "lint": "npm run lint:prettier && npm run lint:eslint",
    "lint:eslint": "eslint --color --cache --cache-location .eslintcache .",
    "lint:prettier": "prettier \"**/*.ts\" --check",
    "format": "npm run format:prettier && npm run format:prettier",
    "format:prettier": "prettier \"**/*.ts\" --write",
    "format:eslint": "eslint --color --cache --fix --cache-location .eslintcache .",
    "test": "npx lupa test",
    "test:watch": "npx lupa test --watch",
    "test:coverage": "npx lupa test --coverage",
    "prepare": "husky",
    "dev": "wds --watch --config web-dev-server.config.js",
    "tsc:all": "tsc --project tsconfig.json"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@commitlint/types": "^21.0.1",
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^10.0.1",
    "@pawel-up/lupa": "^0.2.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@to-skills/typedoc": "^1.0.9",
    "@web/dev-server": "^0.4.3",
    "@web/dev-server-esbuild": "^1.0.2",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "lit": "^3.3.3",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "sinon": "^22.0.0",
    "tslib": "^2.6.2",
    "tsx": "^4.22.0",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.56.1"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix"
    ],
    "*.ts": [
      "eslint --fix"
    ],
    "*.json": [
      "prettier --write"
    ]
  }
}
